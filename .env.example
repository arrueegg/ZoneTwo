# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback

# Garmin
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
GARMIN_REDIRECT_URI=http://localhost:8000/auth/garmin/callback

# Database (SQLite for local dev; swap to postgresql+asyncpg://... for production)
DATABASE_URL=sqlite+aiosqlite:///./training_app.db
# Redis (local default). If using docker-compose services, use redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# Groq (free tier — https://console.groq.com/keys)
GROQ_API_KEY=

# App
SECRET_KEY=your-secret-key-here
FRONTEND_URL=http://localhost:3000
